{
  "name": "quanluong-app-be",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "worker:email-verification": "node src/workers/email-verification.worker.js",
    "worker:email-verification:dev": "nodemon --watch src src/workers/email-verification.worker.js",
    "worker:avatar-processing": "node src/workers/avatar-processing.worker.js",
    "worker:avatar-processing:dev": "nodemon --watch src src/workers/avatar-processing.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:recover": "bash scripts/prisma-migrate-deploy-recover.sh",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:resolve": "prisma migrate resolve",
    "seed:meal-allowance": "node scripts/seed-meal-allowance-rates.js",
    "db:reset-email-verification": "node scripts/reset-email-verification.js",
    "db:migrate": "docker compose --env-file .env.docker run --rm migrate",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:redis": "docker compose --env-file .env.docker up -d redis",
    "docker:worker:email": "docker compose --env-file .env.docker up -d worker-email",
    "docker:worker:media": "docker compose --env-file .env.docker up -d worker-media",
    "docker:dev": "docker compose -f docker-compose.dev.yml --env-file .env.docker up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml --env-file .env.docker up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml --env-file .env.docker down",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f",
    "docker:migrate": "npm run db:migrate"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.47.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "googleapis": "^140.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "node-cron": "^4.0.7",
    "nodemailer": "^6.10.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "redis": "^5.11.0",
    "sharp": "^0.34.1",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "prisma": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
