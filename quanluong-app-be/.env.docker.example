# Sao chép thành `.env.docker` — biến môi trường khi chạy `docker compose`.
# Lệnh: npm run docker:up | npm run docker:migrate | npm run docker:down
#
# Bảo mật:
# - Production: NODE_ENV=production; JWT_ACCESS_SECRET / SESSION_SECRET mỗi cái ≥32 ký tự, không dùng change-me
#   (tạo: openssl rand -hex 32). Ứng dụng sẽ từ chối khởi động nếu secret mẫu/quá ngắn.
# - RUN_SUPERADMIN_BOOTSTRAP: chỉ đặt true khi cần tạo superadmin lần đầu (DB chưa có user đó); sau đó đặt false.
# - SUPERADMIN_PASSWORD: với bootstrap bật trên production, mật khẩu phải đủ mạnh (không pattern changeme).
NODE_ENV=development
PORT=3000
# Socket.io publish :3030 trong docker-compose — phải khớp
SOCKET_PORT=3030
TZ=Asia/Ho_Chi_Minh
APP_NAME=quanluong-app-be

DB_ROOT_PASSWORD=change-me
DB_NAME=quanluong
DATABASE_URL=mysql://root:change-me@db:3306/quanluong

# BullMQ — bắt buộc để API đẩy job; kèm service worker-email trong docker compose
REDIS_URL=redis://redis:6379

# Dev Docker: thay bằng `openssl rand -hex 32` (mỗi biến một giá trị). Không commit secret production.
JWT_ACCESS_SECRET=replace_me_openssl_rand_hex_32_bytes_min_32_chars___
SESSION_SECRET=replace_me_session_openssl_rand_hex_32_different_value__
SESSION_COOKIE_NAME=ql.sid
ACCESS_TOKEN_COOKIE_NAME=ql.at
REFRESH_TOKEN_COOKIE_NAME=ql.rt
# Cookie ql.at: maxAge đồng bộ TTL JWT (trừ vài giây); định dạng giống jwt.sign expiresIn
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
# Hai subdomain (app + superadmin) cùng HTTPS: vd. `.trankhanhan.site` để cookie đăng nhập dùng chung.
# Để trống nếu một host duy nhất. Dev :8080 vs :8081 không share cookie — cần đăng nhập riêng từng cổng.
#COOKIE_DOMAIN=.your-domain.com
PERMISSION_SYNC_ON_BOOT=true
# Lần đầu DB trống: true → khởi động → kiểm tra đăng nhập superadmin → false
RUN_SUPERADMIN_BOOTSTRAP=false
SUPERADMIN_EMAIL=superadmin@quanluong.local
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_FULL_NAME=Super Admin
REGISTRATION_REQUIRES_APPROVAL=true
MIN_UNIT_DEPTH_TO_APPROVE_REGISTRATION=0

# Toàn app: số request tối đa / IP / 15 phút cho toàn `/api` (tránh 429 khi SPA nhiều tab + cùng WiFi).
# Mặc định trong code 1200 nếu không set. Production có WAF/CDN có thể chỉnh lại.
#GLOBAL_API_RATE_LIMIT_MAX=1200

# Docker gộp (nginx UI :8080, superadmin :8081): trùng origin với URL người dùng mở trình duyệt
# Có thể thêm UI_MAIN_ORIGIN / UI_SUPERADMIN_ORIGIN khi build image UI (compose dùng làm build-arg, mặc định :8080/:8081)
# Backend tự thêm cặp http://127.0.0.1:<port> cho mỗi http://localhost:<port> trong danh sách (và ngược lại).
# Truy cập bằng IP LAN (vd. http://192.168.1.5:8080): thêm origin đầy đủ vào CORS_ORIGINS rồi rebuild/restart app.
CORS_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173,http://localhost:5174
# URL gốc trang web (không slash cuối). Phải trùng origin người dùng mở UI — sau OAuth Google redirect về đây (?google=linked|error).
PUBLIC_WEB_URL=http://localhost:8080
REQUIRE_EMAIL_VERIFICATION=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev stack hiện chạy UI :8080 và backend :3000, không proxy /api qua UI; callback OAuth phải về backend :3000.
# Prod/nginx có proxy /api qua UI thì có thể đổi lại http://localhost:8080/api/auth/google/drive/callback hoặc domain thật tương ứng.
# Nếu mở UI bằng http://127.0.0.1:8080 thì đặt GOOGLE_REDIRECT_URI và Console cùng 127.0.0.1 (localhost và 127.0.0.1 là hai URI khác nhau).
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/drive/callback
# Mẫu chứng từ quyết toán: refresh token tài khoản Google chứa thư mục template (thường superadmin/Gmail gửi; scope đủ Drive + spreadsheets.readonly).
CHUNG_TU_SYSTEM_DRIVE_REFRESH_TOKEN=
CHUNG_TU_SYSTEM_TEMPLATE_FOLDER_ID=
MAIL_TRANSPORT=smtp
GMAIL_SENDER_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@quanluong.local

# File tĩnh: volume Docker gắn vào /data/media; nginx UI phục vụ GET /media/* (xem docker-compose + nginx)
MEDIA_ROOT=/data/media
MEDIA_PUBLIC_PATH=/media

# Báo cáo ẩn `/midnight-secret` (Next.js gate + header `X-Midnight-Secret` tới API).
# Phải trùng giữa backend và apps/web (cookie HMAC + proxy).
MIDNIGHT_SECRET_PASSWORD=
