# ── Quy ước: chạy stack qua Docker (.env.docker + docker compose). ──
# 1) cp .env.docker.example .env.docker  → chỉnh DB_ROOT_PASSWORD / DATABASE_URL trong file đó nếu cần
# 2) npm run docker:up
# 3) DB migrate: npm run docker:migrate
#
# Chỉ khi bạn chạy Prisma / Node trên máy (npm run dev) nhưng DB vẫn trong Docker,
# dùng cổng đã publish: MariaDB 3307, Redis 6380 (xem docker-compose.yml).
#
# JWT / SESSION: dev dùng chuỗi dài riêng (openssl rand -hex 32). Production: ≥32 ký tự, không change-me (server từ chối nếu yếu).
NODE_ENV=development
PORT=3000
# Socket.io: 0 hoặc để trống = gắn cùng cổng API. Tách luồng (vd. Docker): 3030 — khớp publish trong docker-compose
SOCKET_PORT=0
APP_NAME=quanluong-app-be
DATABASE_URL="mysql://root:change-me@localhost:3307/quanluong"
# Docker: redis publish 6380 — cần Redis + worker để BullMQ gửi mail: `npm run docker:redis` rồi `npm run worker:email-verification` (hoặc `npm run docker:up` đã gồm worker-email)
REDIS_URL=redis://localhost:6380
JWT_ACCESS_SECRET=localdev_jwt_openssl_rand_hex_32_replace_me_________
SESSION_SECRET=localdev_session_openssl_rand_hex_32_replace_me_______
SESSION_COOKIE_NAME=ql.sid
ACCESS_TOKEN_COOKIE_NAME=ql.at
REFRESH_TOKEN_COOKIE_NAME=ql.rt
# Cùng định dạng với jwt.sign expiresIn; cookie ql.at dùng maxAge ≈ TTL này (trừ vài giây)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
# Hai subdomain (app + superadmin): vd. `.example.com` — cookie phiên dùng chung (HTTPS production)
#COOKIE_DOMAIN=
PERMISSION_SYNC_ON_BOOT=true
# Tạo superadmin lần đầu (DB trống): true một lần rồi false
RUN_SUPERADMIN_BOOTSTRAP=false
SUPERADMIN_EMAIL=superadmin@quanluong.local
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_FULL_NAME=Super Admin
# Đăng ký: false = kích hoạt ngay; true (mặc định) = chờ admin trong nhánh duyệt
REGISTRATION_REQUIRES_APPROVAL=true
# Độ sâu đơn vị tối thiểu (depth) của admin được duyệt đăng ký; 0 = mọi admin trong phạm vi subtree
MIN_UNIT_DEPTH_TO_APPROVE_REGISTRATION=0
# Production: bắt buộc khai báo. Development: luôn có sẵn http://localhost:5173; có thể thêm origin khác (vd. 127.0.0.1)
CORS_ORIGINS=http://localhost:5173
# URL gốc của web app (dùng trong link xác minh email)
PUBLIC_WEB_URL=http://localhost:5173
# true = bắt buộc xác minh email trước khi đăng nhập (kèm gửi mail nếu có SMTP)
REQUIRE_EMAIL_VERIFICATION=false
# Google OAuth — GOOGLE_REDIRECT_URI phải trùng từng ký tự với "Authorized redirect URIs" (OAuth client loại Web).
# Lỗi 400 redirect_uri_mismatch: sửa Console hoặc .env cho khớp (http/https, host, cổng, path; localhost ≠ 127.0.0.1).
# Backend trực tiếp PORT=3000: dùng :3000 bên dưới. Docker/nginx UI :8080: dùng http://localhost:8080/api/auth/google/drive/callback (xem .env.docker.example).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/drive/callback
# Mẫu chứng từ quyết toán (Google Docs/Sheet): OAuth refresh token của tài khoản chứa thư mục template (khuyến nghị superadmin hoặc cùng tài khoản GMAIL_SENDER nếu Google Console bật đủ scope: Drive + spreadsheets.readonly).
CHUNG_TU_SYSTEM_DRIVE_REFRESH_TOKEN=
# Tuỳ chọn: Drive folder ID thư mục mẫu; để trống → midnight-app/chung-tu-quyet-toan-template trên My Drive tài khoản đó (tự tạo).
CHUNG_TU_SYSTEM_TEMPLATE_FOLDER_ID=
# Gửi mail: smtp (mặc định) hoặc gmail_api — bật Gmail API trên Google Cloud, OAuth client giống GOOGLE_* bên dưới
MAIL_TRANSPORT=smtp
# Khi MAIL_TRANSPORT=gmail_api: refresh token của hộp thư gửi (scope https://www.googleapis.com/auth/gmail.send), lấy một lần qua OAuth Playground / script
GMAIL_SENDER_REFRESH_TOKEN=
# Email gửi đi (phải trùng tài khoản Google đã cấp refresh token)
GMAIL_SENDER_EMAIL=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@quanluong.local

# Ảnh đại diện & media: mặc định ./storage/media (gitignore); Docker dùng MEDIA_ROOT=/data/media
# MEDIA_ROOT=
# MEDIA_PUBLIC_PATH=/media
