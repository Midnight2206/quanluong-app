# Gọi API qua proxy Vite (mặc định) hoặc URL tuyệt đối
# VITE_API_BASE_URL=/api

# Origin cổng superadmin — tùy chọn: nếu bỏ trống, app tự suy :8080→:8081 (Docker) hoặc :5173→:5174 (Vite)
# VITE_SUPERADMIN_ORIGIN=http://localhost:8081

# Origin app chính — tùy chọn (cùng quy tắc suy ngược :8081→:8080, :5174→:5173)
# VITE_MAIN_APP_ORIGIN=http://localhost:8080
