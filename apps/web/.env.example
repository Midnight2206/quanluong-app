# ── App web (Next.js) — sao chép thành `.env.local` trong thư mục apps/web ──
# Next đọc `.env.local` / `.env` khi dev & build. Biến NEXT_PUBLIC_* được nhúng vào bundle lúc build.
#
# Docker Compose dev (UI :8080, API :3000, socket :3030) — ví dụ:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
#   NEXT_PUBLIC_SOCKET_BASE_URL=http://localhost:3030
#   NEXT_PUBLIC_MAIN_APP_ORIGIN=http://localhost:8080
#   NEXT_PUBLIC_SUPERADMIN_ORIGIN=http://localhost:8081
#
# Chạy `next dev` trực tiếp (API localhost:3000, web :3000 khác app — chỉnh cổng trong lệnh next):
#   Sửa URL cho khớp cổng bạn mở trình duyệt.

# URL gốc API mà trình duyệt gọi (axios). Có `/api` suffix.
# Cùng origin với UI + reverse proxy: có thể dùng `/api` (xem next.config rewrites).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Chỉ server (RSC / server-only fetch): URL tuyệt đối tới backend trong mạng Docker.
# `next dev` trên máy host: thường cùng giá trị public hoặc http://localhost:3000/api
# Trong container UI: http://app:3000/api (compose service `app`)
API_BASE_URL_INTERNAL=http://localhost:3000/api

# Chat Socket.io — không có `/api`. Ưu tiên 1 trong 2 cách:
# (1) Origin đầy đủ (Docker dev socket publish 3030):
NEXT_PUBLIC_SOCKET_BASE_URL=http://localhost:3030
# (2) Hoặc chỉ cổng — client ghép với hostname hiện tại:
# NEXT_PUBLIC_SOCKET_PORT=3030

# Origin app chính & superadmin (menu, link chuyển app). Khớp URL bạn mở trên trình duyệt (localhost vs 127.0.0.1 là khác origin).
NEXT_PUBLIC_MAIN_APP_ORIGIN=http://localhost:8080
NEXT_PUBLIC_SUPERADMIN_ORIGIN=http://localhost:8081

# Tuỳ chọn: origin phục vụ ảnh /media khi API khác host với UI (avatar). Để trống = dùng đường dẫn tương đối /media trên cùng origin
# NEXT_PUBLIC_MEDIA_PUBLIC_ORIGIN=http://localhost:3000

# Tuỳ chọn: proxy /socket.io trong next.config khi NEXT_PUBLIC_API_BASE_URL=/api và cần chỉ backend thật
# NEXT_INTERNAL_API_ORIGIN=http://localhost:3000

# Tên cookie (khớp backend; mặc định như dưới — chỉ đổi nếu API dùng tên khác)
# ACCESS_TOKEN_COOKIE_NAME=ql.at
# REFRESH_TOKEN_COOKIE_NAME=ql.rt
